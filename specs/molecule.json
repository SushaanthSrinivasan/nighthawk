                "name": "TEXT",
                "suggestions": [
                  "delegated",
                  "docker",
                  "podman",
                  "vagrant",
                  "azure",
                  "hetzner"
                ]
              }
            },
            {
              "names": [
                "--lint-name"
              ],
              "description": "Name of lint to initialize. (yamllint)",
              "takes_arg": true,
              "arg": {
                "name": "TEXT",
                "suggestions": [
                  "yamllint"
                ]
              }
            },
            {
              "names": [
                "--provisioner-name"
              ],
              "description": "Name of provisioner to initialize. (ansible)",
              "takes_arg": true,
              "arg": {
                "name": "TEXT",
                "suggestions": [
                  "ansible"
                ]
              }
            },
            {
              "names": [
                "--role-name",
                "-r"
              ],
              "description": "Name of the role to create",
              "takes_arg": true,
              "arg": {
                "name": "TEXT"
              }
            },
            {
              "names": [
                "--verifier-name"
              ],
              "description": "Name of verifier to initialize. (ansible)",
              "takes_arg": true,
              "arg": {
                "name": "TEXT",
                "suggestions": [
                  "ansible",
                  "testinfra"
                ]
              }
            }
          ],
          "args": [
            {
              "name": "SCENARIO_NAME"
            }
          ]
        }
      ]
