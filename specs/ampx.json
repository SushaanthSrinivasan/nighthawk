{
  "name": "ampx",
  "description": "CLI for Amplify Gen 2",
  "subcommands": [
    {
      "name": "sandbox",
      "description": "Deploy to your personal cloud sandbox",
      "subcommands": [
        {
          "name": "delete",
          "description": "Delete your personal cloud sandbox",
          "options": [
            {
              "names": [
                "--name"
              ],
              "description": "Name to distinguish between sandbox environments",
              "takes_arg": true,
              "arg": {
                "name": "name"
              }
            },
            {
              "names": [
                "--profile"
              ],
              "description": "AWS profile name",
              "takes_arg": true,
              "arg": {
                "name": "profile"
              }
            },
            {
              "names": [
                "-y",
                "--yes"
              ],
              "description": "Do not ask for confirmation before deleting"
            }
          ]
        },
        {
          "name": "secret",
          "description": "Manage backend secrets for your personal cloud sandbox",
          "subcommands": [
            {
              "name": "set",
              "description": "Set a secret",
              "options": [
                {
                  "names": [
                    "--profile"
                  ],
                  "description": "AWS profile name",
                  "takes_arg": true,
                  "arg": {
                    "name": "profile"
                  }
                }
              ],
              "args": [
                {
                  "name": "secret_name"
                }
              ]
            },
            {
              "name": "remove",
              "description": "Remove a secret",
              "options": [
                {
                  "names": [
                    "--profile"
                  ],
                  "description": "AWS profile name",
                  "takes_arg": true,
                  "arg": {
                    "name": "profile"
                  }
                }
              ],
              "args": [
                {
                  "name": "secret_name"
                }
              ]
            },
            {
              "name": "list",
              "description": "List all available secrets",
              "options": [
                {
                  "names": [
                    "--profile"
                  ],
                  "description": "AWS profile name",
                  "takes_arg": true,
                  "arg": {
                    "name": "profile"
                  }
                }
              ]
            },
            {
              "name": "get",
              "description": "View details of a secret",
              "options": [
                {
                  "names": [
                    "--profile"
                  ],
                  "description": "AWS profile name",
                  "takes_arg": true,
                  "arg": {
                    "name": "profile"
                  }
                }
              ],
              "args": [
                {
                  "name": "secret_name"
                }
              ]
            }
          ]
        }
      ],
      "options": [
        {
          "names": [
            "--dir-to-watch"
          ],
          "description": "Directory to watch for file changes",
          "takes_arg": true,
          "arg": {
            "name": "directory",
            "template": "folders"
          }
        },
        {
          "names": [
            "--exclude"
          ],
          "description": "Paths or glob patterns to ignore",
          "takes_arg": true,
          "arg": {
            "name": "pattern"
          }
        },
        {
          "names": [
            "--identifier"
          ],
          "description": "Name to distinguish between sandbox environments",
          "takes_arg": true,
          "arg": {
            "name": "name"
          }
        },
        {
          "names": [
            "--outputs-out-dir"
          ],
          "description": "Directory where client config file is written",
          "takes_arg": true,
          "arg": {
            "name": "directory",
            "template": "folders"
          }
        },
        {
          "names": [
            "--outputs-format"
          ],
          "description": "Format of the client config file",
          "takes_arg": true,
          "arg": {
            "name": "format",
            "suggestions": [
              "json",
              "dart"
            ]
          }
        },
        {
          "names": [
            "--outputs-version"
          ],
          "description": "Version of the configuration",
          "takes_arg": true,
          "arg": {
            "name": "version",
            "suggestions": [
              "0",
              "1"
            ]
          }
        },
        {
          "names": [
            "--profile"
          ],
          "description": "AWS profile name",
          "takes_arg": true,
          "arg": {
            "name": "profile"
          }
        },
        {
          "names": [
            "--stream-function-logs"
          ],
          "description": "Stream function execution logs",
          "takes_arg": true,
          "arg": {
            "name": "boolean",
            "suggestions": [
              "true",
              "false"
            ]
          }
        },
        {
          "names": [
            "--logs-filter"
          ],
          "description": "Regex pattern to filter logs",
          "takes_arg": true,
          "arg": {
            "name": "pattern"
          }
        },
        {
          "names": [
            "--logs-out-file"
          ],
          "description": "File to append streaming logs",
          "takes_arg": true,
          "arg": {
            "name": "file",
            "template": "filepaths"
          }
        }
      ]
    },
    {
      "name": "generate",
      "description": "Generate supplemental information or code",
      "subcommands": [
        {
          "name": "outputs",
          "description": "Generate backend outputs file",
          "options": [
            {
              "names": [
                "--profile"
              ],
              "description": "AWS profile name",
              "takes_arg": true,
              "arg": {
                "name": "profile"
              }
            },
            {
              "names": [
                "--format"
              ],
              "description": "Format of the configuration",
              "takes_arg": true,
              "arg": {
                "name": "format",
                "suggestions": [
                  "json",
                  "dart"
                ]
              }
            },
            {
              "names": [
                "--out-dir"
              ],
              "description": "Directory where config is written",
              "takes_arg": true,
              "arg": {
                "name": "directory",
                "template": "folders"
              }
            },
            {
              "names": [
                "--outputs-version"
              ],
              "description": "Version of the configuration",
              "takes_arg": true,
              "arg": {
                "name": "version",
                "suggestions": [
                  "0",
                  "1"
                ]
              }
            },
            {
              "names": [
                "--branch"
              ],
              "description": "Git branch name",
              "takes_arg": true,
              "arg": {
                "name": "branch_name"
              }
            },
            {
              "names": [
                "--app-id"
              ],
              "description": "Amplify App ID",
              "takes_arg": true,
              "arg": {
                "name": "app_id"
              }
            }
          ]
        },
        {
          "name": "graphql-client-code",
          "description": "Generate GraphQL statements and types",
          "options": [
            {
              "names": [
                "--out"
              ],
              "description": "Directory where config is written",
              "takes_arg": true,
              "arg": {
                "name": "directory",
                "template": "folders"
              }
            },
            {
              "names": [
                "--format"
              ],
              "description": "Format of the GraphQL client code",
              "takes_arg": true,
              "arg": {
                "name": "format",
                "suggestions": [
                  "modelgen",
                  "graphql-codegen",
                  "introspection"
                ]
              }
            },
            {
              "names": [
                "--model-target"
              ],
              "description": "Modelgen export target",
              "takes_arg": true,
              "arg": {
                "name": "target",
                "suggestions": [
                  "java",
                  "swift",
                  "javascript",
                  "typescript",
                  "dart"
                ]
              }
            },
            {
              "names": [
                "--statement-target"
              ],
              "description": "Graphql codegen statement export target",
              "takes_arg": true,
              "arg": {
                "name": "target",
                "suggestions": [
                  "javascript",
                  "graphql",
                  "flow",
                  "typescript",
                  "angular"
                ]
              }
            },
            {
              "names": [
                "--type-target"
              ],
              "description": "Graphql-codegen type export target",
              "takes_arg": true,
              "arg": {
                "name": "target",
                "suggestions": [
                  "json",
                  "swift",
                  "typescript",
                  "flow",
                  "scala",
                  "flow-modern",
                  "angular"
                ]
              }
            },
            {
              "names": [
                "--all"
              ],
              "description": "Show hidden options"
            },
            {
              "names": [
                "--profile"
              ],
              "description": "AWS profile name",
              "takes_arg": true,
              "arg": {
                "name": "profile"
              }
            },
            {
              "names": [
                "--debug"
              ],
              "description": "Print debug logs to the console"
            },
            {
              "names": [
                "--statement-max-depth"
              ],
              "description": "Maximum depth of the generated GraphQL statements",
              "takes_arg": true,
              "arg": {
                "name": "integer"
              }
            }
          ]
        },
        {
          "name": "forms",
          "description": "Generate React form components",
          "options": [
            {
              "names": [
                "--out-dir"
              ],
              "description": "Directory where generated forms are written",
              "takes_arg": true,
              "arg": {
                "name": "directory",
                "template": "folders"
              }
            },
            {
              "names": [
                "--models"
              ],
              "description": "Model names to generate",
              "takes_arg": true,
              "arg": {
                "name": "model"
              }
            },
            {
              "names": [
                "--profile"
              ],
              "description": "AWS profile name",
              "takes_arg": true,
              "arg": {
                "name": "profile"
              }
            }
          ]
        }
      ],
      "options": [
        {
          "names": [
            "--stack"
          ],
          "description": "CloudFormation stack name",
          "takes_arg": true,
          "arg": {
            "name": "stack_name"
          }
        },
        {
          "names": [
            "--app-id"
          ],
          "description": "Amplify App ID",
          "takes_arg": true,
          "arg": {
            "name": "app_id"
          }
        },
        {
          "names": [
            "--branch"
          ],
          "description": "Git branch name",
          "takes_arg": true,
          "arg": {
            "name": "branch_name"
          }
        },
        {
          "names": [
            "--profile"
          ],
          "description": "AWS profile name",
          "takes_arg": true,
          "arg": {
            "name": "profile"
          }
        }
      ]
    },
    {
      "name": "info",
      "description": "Generate system information for troubleshooting"
    },
    {
      "name": "pipeline-deploy",
      "description": "Deploy Amplify project in a CI/CD pipeline",
      "options": [
        {
          "names": [
            "--branch"
          ],
          "description": "Name of the git branch being deployed",
          "takes_arg": true,
          "arg": {
            "name": "branch_name"
          }
        },
        {
          "names": [
            "--app-id"
          ],
          "description": "The app id of the target Amplify app",
          "takes_arg": true,
          "arg": {
            "name": "app_id"
          }
        },
        {
          "names": [
            "--outputs-out-dir"
          ],
          "description": "Directory where client config file is written",
          "takes_arg": true,
          "arg": {
            "name": "directory",
            "template": "folders"
          }
        },
        {
          "names": [
            "--outputs-version"
          ],
          "description": "Version of the configuration",
          "takes_arg": true,
          "arg": {
            "name": "version",
            "suggestions": [
              "0",
              "1"
            ]
          }
        }
      ]
    }
  ],
  "options": [
    {
      "names": [
        "--help"
      ],
      "description": "Display help information"
    },
    {
      "names": [
        "--version",
        "-v"
      ],
      "description": "Display version information"
    },
    {
      "names": [
        "--profile"
      ],
      "description": "AWS profile name",
      "takes_arg": true,
      "arg": {
        "name": "profile"
      }
    }
  ]
}
