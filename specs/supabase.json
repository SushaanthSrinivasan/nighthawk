      ]
    }
  ],
  "options": [
    {
      "names": [
        "--debug"
      ],
      "description": "Output debug logs to stderr"
    },
    {
      "names": [
        "--help",
        "-h"
      ],
      "description": "Display help"
    }
  ]
}
