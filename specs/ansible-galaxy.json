        {
          "name": "publish",
          "description": "Publish collections",
          "options": [
            {
              "names": [
                "--server",
                "-s"
              ],
              "description": "The Galaxy API server URL",
              "takes_arg": true
            },
            {
              "names": [
                "--token",
                "--api-key"
              ],
