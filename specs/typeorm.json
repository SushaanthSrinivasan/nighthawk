        {
          "names": [
            "--help"
          ],
          "description": "Show help for command"
        },
        {
          "names": [
            "-c",
            "--connection"
          ],
          "description": "Name of the connection on which schema synchronization needs to to run",
          "takes_arg": true
        },
        {
          "names": [
            "-f",
            "--config"
          ],
          "description": "Name of the file with connection configuration",
          "takes_arg": true
        },
        {
