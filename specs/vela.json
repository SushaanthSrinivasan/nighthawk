        {
          "names": [
            "--env",
            "-e"
          ],
          "description": "The environment name for the CLI request",
          "takes_arg": true
        },
        {
          "names": [
            "--file",
            "-f"
          ],
          "description": "The file path for appfile or application. It could be a remote url",
