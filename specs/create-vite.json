      "takes_arg": true,
      "arg": {
        "name": "template",
        "suggestions": [
          "vanilla",
          "vanilla-ts",
          "vue",
          "vue-ts",
          "react",
          "react-ts",
          "react-swc",
          "react-swc-ts",
          "preact",
          "preact-ts",
          "lit",
          "lit-ts",
          "svelte",
          "svelte-ts",
          "solid",
          "solid-ts",
          "qwik",
          "qwik-ts"
        ]
      },
      "is_required": true
    }
  ],
  "args": [
    {
      "name": "projectName",
      "description": "Project name"
    }
  ]
}
