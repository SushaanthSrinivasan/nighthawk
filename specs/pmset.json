            "wake",
            "poweron",
            "shutdown",
            "wakeorpoweron"
          ]
        },
        {
          "name": "weekdays",
          "description": "A subset of MTWRFSU (\"M\" and \"MTWRF\" are valid strings)"
        },
        {
          "name": "date/time",
          "description": "\"MM/dd/yy HH:mm:ss\" (in 24 hour format; must be in quotes)"
        }
      ]
    }
