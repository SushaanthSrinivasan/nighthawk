    {
      "names": [
        "-v",
        "--verbose"
      ],
      "description": "Enable verbose logging"
    },
    {
      "names": [
        "-q",
        "--quiet"
      ],
      "description": "Print diagnostics, but nothing else"
    },
    {
      "names": [
        "-s",
        "--silent"
      ],
