{
  "name": "wrk",
  "description": "Wrk - a HTTP benchmarking tool",
  "options": [
    {
      "names": [
        "-c",
        "--c"
      ],
      "description": "Connections to keep open",
      "takes_arg": true,
      "arg": {
        "name": "Number"
      }
    },
    {
      "names": [
        "-d",
        "--duration"
      ],
      "description": "Duration of test",
      "takes_arg": true,
      "arg": {
        "name": "Time"
      }
    },
    {
      "names": [
        "-t",
        "--threads"
      ],
      "description": "Number of threads",
      "takes_arg": true,
      "arg": {
        "name": "Number"
      }
    },
    {
      "names": [
        "-s",
        "--script"
      ],
      "description": "Load Lua script file",
      "takes_arg": true,
      "arg": {
        "name": "Script"
      }
    },
    {
      "names": [
        "-H",
        "--header"
      ],
      "description": "Add header to request",
      "takes_arg": true,
      "arg": {
        "name": "Header"
      }
    },
    {
      "names": [
        "--latency"
      ],
      "description": "Print latency statistics"
    },
    {
      "names": [
        "--timeout"
      ],
      "description": "Socket/request timeout",
      "takes_arg": true,
      "arg": {
        "name": "Time"
      }
    },
    {
      "names": [
        "-v",
        "--version"
      ],
      "description": "Print version details"
    },
    {
      "names": [
        "-h",
        "--help"
      ],
      "description": "Output usage information"
    }
  ],
  "args": [
    {
      "name": "Url"
    }
  ]
}
